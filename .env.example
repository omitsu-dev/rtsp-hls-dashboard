# Camera RTSP URLs
# Add as many cameras as needed: CAM1, CAM2, CAM3, ...
# Format: CAM{N}_RTSP_URL=rtsp://user:pass@host:554/path
# Optional: CAM{N}_NAME=Human readable name

CAM1_RTSP_URL=rtsp://admin:password@192.168.1.64:554/Streaming/Channels/101
CAM1_NAME=Entrance

CAM2_RTSP_URL=rtsp://admin:password@192.168.1.108:554/cam/realmonitor?channel=1&subtype=0
CAM2_NAME=Server Room

CAM3_RTSP_URL=rtsp://admin:password@192.168.1.100:554/onvif1
CAM3_NAME=Parking

# HLS output directory (default: /var/www/hls)
# HLS_BASE_DIR=/var/www/hls

# API port (default: 3001)
# API_PORT=3001
